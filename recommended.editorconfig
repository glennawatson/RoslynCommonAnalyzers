dotnet_diagnostic.SST2413.severity = warning # A for loop's body should be able to run
dotnet_diagnostic.SST2414.severity = warning # Two branches should not share an implementation
dotnet_diagnostic.SST2415.severity = warning # A boolean guard should short-circuit
dotnet_diagnostic.SST2416.severity = warning # A remainder test should account for negative values
dotnet_diagnostic.SST2417.severity = warning # An assignment should not read as a transposed operator
dotnet_diagnostic.SST2418.severity = warning # The result of an immutable value's method should be used
