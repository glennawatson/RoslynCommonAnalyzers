# StyleSharp.Analyzers — recommended .editorconfig preset
#
# Drop this in (or merge it into) the .editorconfig at your repository root to adopt
# the StyleSharp rule set with sensible defaults. Every rule below is already enabled
# by default at Warning severity — listing them explicitly just gives you a single
# place to tune severities (warning / suggestion / error / none) per rule.
#
# Lines that are commented out are the OPT-IN rules: off by default because they are
# opinionated or situational. Uncomment one to turn it on. See docs/CONFIGURATION.md
# and docs/rules/SSTxxxx.md for what each rule does.
#
# Configurable options (uncomment and adjust):
# stylesharp.tuple_element_naming = pascal_case            # SST1316
# stylesharp.union_member_naming = pascal_case             # SST1315
# stylesharp.record_parameter_naming = pascal_case         # SST1801
# stylesharp.conditional_operator_placement = leading      # SST1145
# stylesharp.collection_expression_spacing = none          # SST1010/1011 (set 'space' for padded '[ 1, 2 ]')
# stylesharp.instance_member_qualification = omit_this     # SST1117 (omit_this | require_this)
# stylesharp.summary_single_line_max_length = 100          # SST1653
# stylesharp.namespace_root = MyCompany.MyProduct          # SST1417 (also reads MSBuild RootNamespace)
# stylesharp.max_switch_sections = 30                      # SST1423
# stylesharp.max_parameters = 7                            # SST1472
# stylesharp.check_positional_records = false              # SST1472 (set true to measure positional records too)
# stylesharp.count_optional_parameters = true              # SST1472 (set false to count only required parameters)
# stylesharp.max_cyclomatic_complexity = 10                 # SST1442
# stylesharp.max_cognitive_complexity = 15                  # SST1443
# stylesharp.max_property_cognitive_complexity = 3          # SST1443
# stylesharp.max_inheritance_depth = 5                     # SST1446
# stylesharp.count_external_types = false                  # SST1446 (set true to count ancestors from other assemblies)
# stylesharp.magic_number_allowed_values = -1, 0, 1        # SST1471 (comma-separated; the values that need no name)
# stylesharp.allowed_enum_storage = int                     # SST2313 (comma-separated; add uint, long, ulong to allow wider enum storage)
# stylesharp.allow_zero_comparison = true                  # SST1473 (set false to also report '== 0.0' on a float/double)
# stylesharp.minimum_statements = 1                        # SST1476 (the smallest identical branch body that counts)
# stylesharp.allow_zero_shift = false                      # SST1478 (set true to allow a shift by 0 in a regular table of shifts)
# stylesharp.check_base_types = false                      # SST1484 (set true to also report a field shadowing an inherited one)
# stylesharp.additional_members = Close, Cleanup           # SST1485 (comma-separated; extra members that must not throw)
# stylesharp.duplicate_string_threshold = 3                # SST1486 (occurrences of one literal in a file before it is reported)
# stylesharp.minimum_string_length = 5                     # SST1486 (shorter literals are never reported)
# stylesharp.require_parameterless = true                  # SST1488 (set false where every exception must carry a message)
# stylesharp.include_non_public_types = true               # SST1488 (set false to check only externally visible exceptions)
# stylesharp.include_internal = true                       # SST1499 (set false to report only fields visible outside the assembly)
# stylesharp.max_line_length = 120                         # SST1521 (characters)
# stylesharp.max_file_lines = 500                          # SST1522 (code lines; blank lines and comments do not count)
# stylesharp.max_member_lines = 60                         # SST1523 (code lines)
# stylesharp.max_switch_section_lines = 20                 # SST1524 (code lines)
# stylesharp.allowed_hungarian_prefixes = db, ui           # SST1305 (comma-separated; added to the built-in list)
# stylesharp.extension_container_preferred_suffix = Extensions # SST1704 (Extensions | Mixins)
# stylesharp.file_naming_convention = braces               # SST1402/SST1649 code fixes (braces 'Widget{T}.cs' | metadata 'Widget`1.cs')
# stylesharp.SST1431.additional_per_owner_types = My.Lib.PropertyKey # SST1431 (comma-separated fully-qualified type names)
# stylesharp.SST2438.minimum_level = error                  # SST2438 (trace | debug | information | warning | error | critical; the lowest level a discarded catch exception is reported at)
# stylesharp.document_exposed_elements = true              # SST1600/1601/1602/1654 coverage scope
# stylesharp.document_internal_elements = true             # SST1600/1601/1602/1654 (set false to require only the public API surface)
# stylesharp.document_private_elements = false             # SST1600/1601/1602/1654 (non-field private members)
# stylesharp.document_private_fields = false               # SST1600 (set true to also require private fields)
# stylesharp.document_interfaces = all                     # SST1600/1601 (all | exposed | none)
# stylesharp.binary_operator_new_line = before           # SST1526
# stylesharp.arrow_token_new_line = after                # SST1527
# stylesharp.equals_token_new_line = after               # SST1528
# stylesharp.null_conditional_new_line = before          # SST1529
# stylesharp.line_ending = lf                            # SST1532
# stylesharp.infinite_loop_style = while                 # SST2267
# stylesharp.object_creation_parentheses = omit          # SST2268
# stylesharp.conditional_condition_parentheses = omit_when_single_token  # SST2269
# stylesharp.array_creation_type_style = implicit_when_obvious           # SST2270
# stylesharp.use_var = when_obvious                      # SST2271
# stylesharp.enum_flag_value_style = shift               # SST2272
# stylesharp.min_wrapped_statements = 2                  # SST2273
# stylesharp.SST2326.allowed_types =                     # SST2326 (comma-separated fully-qualified type names)
# stylesharp.SST2601.fieldname = _logger, _log          # SST2601 (logger field names)

[*.cs]

# Spacing
dotnet_diagnostic.SST1000.severity = warning # Keywords should be spaced correctly
dotnet_diagnostic.SST1001.severity = warning # Commas should be spaced correctly
dotnet_diagnostic.SST1002.severity = warning # Semicolons should be spaced correctly
dotnet_diagnostic.SST1003.severity = warning # Symbols should be spaced correctly
dotnet_diagnostic.SST1004.severity = warning # Documentation lines should begin with a single space
dotnet_diagnostic.SST1005.severity = warning # Single-line comments should begin with a single space
dotnet_diagnostic.SST1006.severity = warning # Preprocessor keywords should not be preceded by a space
dotnet_diagnostic.SST1007.severity = warning # Operator keyword should be followed by a space
dotnet_diagnostic.SST1008.severity = warning # Opening parenthesis should be spaced correctly
dotnet_diagnostic.SST1009.severity = warning # Closing parenthesis should be spaced correctly
# dotnet_diagnostic.SST1010.severity = warning # Opening square brackets should be spaced correctly (opt-in)
dotnet_diagnostic.SST1011.severity = warning # Closing square brackets should be spaced correctly
dotnet_diagnostic.SST1012.severity = warning # Opening braces should be spaced correctly
dotnet_diagnostic.SST1013.severity = warning # Closing braces should be spaced correctly
dotnet_diagnostic.SST1014.severity = warning # Opening generic brackets should be spaced correctly
dotnet_diagnostic.SST1015.severity = warning # Closing generic brackets should be spaced correctly
dotnet_diagnostic.SST1016.severity = warning # Opening attribute brackets should be spaced correctly
dotnet_diagnostic.SST1017.severity = warning # Closing attribute brackets should be spaced correctly
dotnet_diagnostic.SST1018.severity = warning # Nullable type symbols should not be preceded by a space
dotnet_diagnostic.SST1019.severity = warning # Member access symbols should be spaced correctly
dotnet_diagnostic.SST1020.severity = warning # Increment and decrement symbols should be spaced correctly
dotnet_diagnostic.SST1021.severity = warning # Negative signs should be spaced correctly
dotnet_diagnostic.SST1022.severity = warning # Positive signs should be spaced correctly
# dotnet_diagnostic.SST1023.severity = warning # Dereference and address-of symbols should be spaced correctly (opt-in)
dotnet_diagnostic.SST1024.severity = warning # Colons should be spaced correctly
dotnet_diagnostic.SST1025.severity = warning # Code should not contain multiple whitespace characters in a row
dotnet_diagnostic.SST1026.severity = warning # Implicit array creation should not contain a space before the bracket
dotnet_diagnostic.SST1027.severity = warning # Use spaces rather than tabs
dotnet_diagnostic.SST1028.severity = warning # Code should not contain trailing whitespace

# Readability
dotnet_diagnostic.SST1100.severity = warning # Do not prefix calls with base unless a local override exists
dotnet_diagnostic.SST1102.severity = warning # Query clause should follow the previous clause
dotnet_diagnostic.SST1103.severity = warning # Query clauses should be on the same line or each on its own line
dotnet_diagnostic.SST1104.severity = warning # Query clause should begin on a new line after a multi-line clause
dotnet_diagnostic.SST1105.severity = warning # Query clauses spanning multiple lines should begin on their own line
dotnet_diagnostic.SST1106.severity = warning # Code should not contain empty statements
dotnet_diagnostic.SST1107.severity = warning # Code should not contain multiple statements on one line
dotnet_diagnostic.SST1110.severity = warning # Opening parenthesis or bracket should be on the declaration line
dotnet_diagnostic.SST1111.severity = warning # Closing parenthesis or bracket should be on the line of the last parameter
dotnet_diagnostic.SST1112.severity = warning # Closing parenthesis should be on the line of the opening parenthesis when the list is empty
dotnet_diagnostic.SST1113.severity = warning # Comma should be on the same line as the previous parameter
dotnet_diagnostic.SST1114.severity = warning # Parameter list should follow the declaration
dotnet_diagnostic.SST1115.severity = warning # A parameter should follow the comma without a blank line
dotnet_diagnostic.SST1116.severity = warning # Prefer the shortest symbol-equivalent name
dotnet_diagnostic.SST1117.severity = warning # Use the configured instance-member qualification
# dotnet_diagnostic.SST1118.severity = warning # A parameter should not span multiple lines (opt-in)
dotnet_diagnostic.SST1119.severity = warning # Digit separators should group digits regularly
dotnet_diagnostic.SST1120.severity = warning # Comments should contain text
# dotnet_diagnostic.SST1121.severity = warning # Use built-in type alias (opt-in)
dotnet_diagnostic.SST1122.severity = warning # Use string.Empty for empty strings
dotnet_diagnostic.SST1123.severity = warning # Do not place regions within elements
dotnet_diagnostic.SST1124.severity = warning # Do not use regions
dotnet_diagnostic.SST1125.severity = warning # Use shorthand for nullable types
dotnet_diagnostic.SST1127.severity = warning # Generic type constraints should be on their own line
dotnet_diagnostic.SST1128.severity = warning # Constructor initializers should be on their own line
dotnet_diagnostic.SST1129.severity = warning # Do not use default value type constructor
dotnet_diagnostic.SST1130.severity = warning # Use lambda syntax
dotnet_diagnostic.SST1131.severity = warning # Use readable conditions
dotnet_diagnostic.SST1132.severity = warning # Do not combine declarations
dotnet_diagnostic.SST1133.severity = warning # Do not combine attributes
dotnet_diagnostic.SST1134.severity = warning # Attributes should not share a line
dotnet_diagnostic.SST1135.severity = warning # Using directives should be qualified
dotnet_diagnostic.SST1136.severity = warning # Enum values should be on separate lines
dotnet_diagnostic.SST1137.severity = warning # Elements should have the same indentation
dotnet_diagnostic.SST1138.severity = warning # A free-standing block that declares nothing should be removed
dotnet_diagnostic.SST1139.severity = warning # Use literal suffix notation instead of casting
dotnet_diagnostic.SST1140.severity = warning # Start conditional operators on indented continuation lines
dotnet_diagnostic.SST1141.severity = warning # Use tuple syntax
dotnet_diagnostic.SST1142.severity = warning # Refer to tuple elements by name
dotnet_diagnostic.SST1143.severity = warning # Do not compare to a boolean literal
# dotnet_diagnostic.SST1144.severity = warning # Combine case labels with an or-pattern (opt-in)
dotnet_diagnostic.SST1145.severity = warning # Place conditional operators consistently
dotnet_diagnostic.SST1146.severity = warning # An if statement should start on a new line
# dotnet_diagnostic.SST1147.severity = warning # Do not nest conditional operators (opt-in)
# dotnet_diagnostic.SST1148.severity = warning # Commented-out code should be removed (opt-in)
dotnet_diagnostic.SST1149.severity = warning # Prefer the 'is null' pattern for null checks
dotnet_diagnostic.SST1150.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1151.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1152.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1153.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1154.severity = warning # Arguments should be on same line or separate lines
dotnet_diagnostic.SST1155.severity = warning # Arguments should be on same line or separate lines
dotnet_diagnostic.SST1156.severity = warning # Arguments should be on same line or separate lines
dotnet_diagnostic.SST1157.severity = warning # Arguments should be on same line or separate lines
dotnet_diagnostic.SST1158.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1159.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1160.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1161.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1162.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1163.severity = warning # Arguments should be on same line or separate lines
dotnet_diagnostic.SST1164.severity = warning # Arguments should be on same line or separate lines
dotnet_diagnostic.SST1165.severity = warning # Arguments should be on same line or separate lines
dotnet_diagnostic.SST1166.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1167.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1168.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1169.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1170.severity = warning # Arguments should be on same line or separate lines
dotnet_diagnostic.SST1171.severity = warning # Parameters should be on same line or separate lines
dotnet_diagnostic.SST1172.severity = warning # Negated comparisons should use the opposite operator
dotnet_diagnostic.SST1173.severity = warning # Redundant anonymous-type member names should be omitted
dotnet_diagnostic.SST1174.severity = warning # Redundant jump statements should be removed
dotnet_diagnostic.SST1175.severity = warning # Unnecessary casts should be removed
# dotnet_diagnostic.SST1176.severity = warning # Members should not be initialized to their default value (opt-in)
dotnet_diagnostic.SST1177.severity = warning # Redundant base types should be removed
dotnet_diagnostic.SST1178.severity = warning # Redundant base constructor calls should be removed
dotnet_diagnostic.SST1179.severity = warning # Redundant default switch sections should be removed
dotnet_diagnostic.SST1180.severity = warning # Empty else clauses should be removed
dotnet_diagnostic.SST1181.severity = warning # Redundant overriding members should be removed
dotnet_diagnostic.SST1182.severity = warning # Conditional expressions should not just return boolean literals
dotnet_diagnostic.SST1183.severity = warning # Interpolated strings without interpolations should be plain strings
dotnet_diagnostic.SST1184.severity = warning # Verbatim string literals without escapes should be regular strings
dotnet_diagnostic.SST1185.severity = warning # Use a compound assignment operator
dotnet_diagnostic.SST1186.severity = warning # A literal should be on the right side of a comparison
dotnet_diagnostic.SST1187.severity = warning # Assignments should not be chained
dotnet_diagnostic.SST1188.severity = warning # Use the 'default' literal instead of 'default(T)'
dotnet_diagnostic.SST1189.severity = warning # Variables should not be self-assigned
dotnet_diagnostic.SST1190.severity = warning # Doubled negation operators should be removed
# dotnet_diagnostic.SST1191.severity = warning # Long numeric literals should use digit separators (opt-in)
# dotnet_diagnostic.SST1192.severity = warning # Control characters in string literals should be escaped (opt-in)
dotnet_diagnostic.SST1193.severity = warning # Keep initial member values with construction
dotnet_diagnostic.SST1194.severity = warning # Keep initial collection values with construction
dotnet_diagnostic.SST1195.severity = warning # Write null fallback with ??
dotnet_diagnostic.SST1196.severity = warning # Write null-guarded access directly
dotnet_diagnostic.SST1197.severity = warning # Collapse return-only branch into one return
dotnet_diagnostic.SST1198.severity = warning # Collapse assignment-only branch into one assignment
dotnet_diagnostic.SST1199.severity = warning # Prefer compile-time type names

# Ordering
dotnet_diagnostic.SST1200.severity = warning # Using directives should be placed outside the namespace
dotnet_diagnostic.SST1201.severity = warning # Elements should be ordered by kind
dotnet_diagnostic.SST1202.severity = warning # Elements should be ordered by access
dotnet_diagnostic.SST1203.severity = warning # Constants should appear before fields
dotnet_diagnostic.SST1204.severity = warning # Static members should appear before instance members
dotnet_diagnostic.SST1205.severity = warning # Partial elements should declare an access modifier
dotnet_diagnostic.SST1206.severity = warning # Declaration keywords should follow the standard order
dotnet_diagnostic.SST1207.severity = warning # Protected should come before internal
dotnet_diagnostic.SST1208.severity = warning # System using directives should appear before other usings
dotnet_diagnostic.SST1209.severity = warning # Using alias directives should appear after other usings
dotnet_diagnostic.SST1210.severity = warning # Using directives should be ordered alphabetically by namespace
dotnet_diagnostic.SST1211.severity = warning # Using alias directives should be ordered alphabetically by alias name
dotnet_diagnostic.SST1212.severity = warning # Property accessors should be ordered with get first
dotnet_diagnostic.SST1213.severity = warning # Event accessors should be ordered with add first
dotnet_diagnostic.SST1214.severity = warning # Static readonly fields should appear before static non-readonly fields
dotnet_diagnostic.SST1215.severity = warning # Instance readonly fields should appear before instance non-readonly fields
dotnet_diagnostic.SST1216.severity = warning # Using static directives should appear after regular usings and before aliases
dotnet_diagnostic.SST1217.severity = warning # Using static directives should be ordered alphabetically
dotnet_diagnostic.SST1218.severity = warning # Method overloads should be grouped together
dotnet_diagnostic.SST1219.severity = warning # A default section should appear last
dotnet_diagnostic.SST1220.severity = suggestion # Named arguments should match the parameter declaration order
dotnet_diagnostic.SST1221.severity = suggestion # Constraint clauses should match the type-parameter declaration order

# Naming
dotnet_diagnostic.SST1300.severity = warning # Element names should be PascalCase
dotnet_diagnostic.SST1302.severity = warning # Interface names should begin with I
dotnet_diagnostic.SST1303.severity = warning # Constant names should be PascalCase
dotnet_diagnostic.SST1304.severity = warning # Non-private readonly fields should be PascalCase
# dotnet_diagnostic.SST1305.severity = warning # Field names should not use Hungarian notation (opt-in)
# dotnet_diagnostic.SST1306.severity = warning # Field names should begin with a lower-case letter (opt-in)
dotnet_diagnostic.SST1307.severity = warning # Accessible fields should be PascalCase
# dotnet_diagnostic.SST1308.severity = warning # Field names should not be prefixed (opt-in)
dotnet_diagnostic.SST1309.severity = warning # Private fields should be _camelCase
# dotnet_diagnostic.SST1310.severity = warning # Field names should not contain underscores (opt-in)
dotnet_diagnostic.SST1311.severity = warning # Static readonly fields should be PascalCase
dotnet_diagnostic.SST1312.severity = warning # Local variables should be camelCase
dotnet_diagnostic.SST1313.severity = warning # Parameters should be camelCase
dotnet_diagnostic.SST1314.severity = warning # Type parameters should begin with T
dotnet_diagnostic.SST1315.severity = warning # Union member names should match the configured casing
dotnet_diagnostic.SST1316.severity = warning # Tuple element names should match the configured casing
dotnet_diagnostic.SST1317.severity = warning # Asynchronous method names should end with 'Async'
dotnet_diagnostic.SST1318.severity = warning # Overriding parameter names should match the base declaration
dotnet_diagnostic.SST1319.severity = warning # Enumeration names should be PascalCase
dotnet_diagnostic.SST1320.severity = warning # Parameter names should not match the method name
dotnet_diagnostic.SST1321.severity = warning # Synchronous method names should not end with 'Async'

# Maintainability
dotnet_diagnostic.SST1400.severity = warning # Access modifier should be declared
dotnet_diagnostic.SST1401.severity = warning # Fields should be private
dotnet_diagnostic.SST1402.severity = warning # File should contain a single type
dotnet_diagnostic.SST1403.severity = warning # File should contain a single namespace
dotnet_diagnostic.SST1404.severity = warning # Code analysis suppression should have justification
dotnet_diagnostic.SST1405.severity = warning # Debug.Assert should provide message text
dotnet_diagnostic.SST1406.severity = warning # Debug.Fail should provide message text
dotnet_diagnostic.SST1407.severity = warning # Arithmetic expressions should declare precedence
dotnet_diagnostic.SST1408.severity = warning # Conditional expressions should declare precedence
dotnet_diagnostic.SST1410.severity = warning # Remove delegate parenthesis when possible
dotnet_diagnostic.SST1411.severity = warning # Attribute constructor should not use unnecessary parenthesis
# dotnet_diagnostic.SST1412.severity = warning # Store files as UTF-8 with a byte order mark (opt-in)
dotnet_diagnostic.SST1413.severity = warning # Use a trailing comma in multi-line initializers
dotnet_diagnostic.SST1414.severity = warning # Tuple types in signatures should have element names
dotnet_diagnostic.SST1415.severity = warning # Use nameof for parameter references
# dotnet_diagnostic.SST1416.severity = warning # Do not declare public members in a non-public type (opt-in)
# dotnet_diagnostic.SST1417.severity = warning # Namespace should match the folder structure (opt-in)
dotnet_diagnostic.SST1418.severity = warning # Declare precedence when mixing the null-coalescing operator
dotnet_diagnostic.SST1419.severity = warning # Remove redundant modifiers
dotnet_diagnostic.SST1420.severity = warning # Trivial properties should be auto-implemented
dotnet_diagnostic.SST1421.severity = warning # Write-only properties should not be used
# dotnet_diagnostic.SST1422.severity = warning # Private fields used only as locals should be local variables (opt-in)
dotnet_diagnostic.SST1423.severity = warning # Switch statements should not have too many sections
# dotnet_diagnostic.SST1424.severity = warning # Fields that are never reassigned should be readonly (opt-in)
dotnet_diagnostic.SST1425.severity = warning # Do not reassign captured primary-constructor parameters
dotnet_diagnostic.SST1426.severity = warning # Use [SuppressMessage] instead of #pragma warning disable
dotnet_diagnostic.SST1427.severity = warning # Protected members of sealed types should not be used
dotnet_diagnostic.SST1428.severity = warning # Abstract types should not declare public constructors
dotnet_diagnostic.SST1429.severity = warning # Empty catch clauses should not swallow the base exception
dotnet_diagnostic.SST1430.severity = warning # Rethrow with 'throw;' to preserve the stack trace
dotnet_diagnostic.SST1431.severity = warning # Static members of a generic type should use a type parameter
# dotnet_diagnostic.SST1432.severity = warning # Classes with only static members should be static (opt-in)
dotnet_diagnostic.SST1433.severity = warning # Redundant constructors should be removed
dotnet_diagnostic.SST1435.severity = warning # Empty namespace declarations should be removed
# dotnet_diagnostic.SST1436.severity = warning # Empty types should not be declared (opt-in)
# dotnet_diagnostic.SST1437.severity = warning # Empty interfaces should not be declared (opt-in)
# dotnet_diagnostic.SST1438.severity = warning # Methods should not be empty (opt-in)
dotnet_diagnostic.SST1439.severity = warning # Nested code blocks should not be left empty
dotnet_diagnostic.SST1440.severity = warning # Remove private members with no local use
dotnet_diagnostic.SST1441.severity = warning # Remove private fields that are never read
dotnet_diagnostic.SST1442.severity = warning # Functions should keep branching complexity low
dotnet_diagnostic.SST1443.severity = warning # Functions should keep nested flow easy to follow
dotnet_diagnostic.SST1444.severity = warning # Loops should do more than one iteration
dotnet_diagnostic.SST1445.severity = warning # Remove unnecessary using directives
dotnet_diagnostic.SST1446.severity = warning # Inheritance chains should stay shallow
dotnet_diagnostic.SST1447.severity = warning # Equality overrides should not delegate to object
dotnet_diagnostic.SST1448.severity = warning # Let the compiler supply caller-info arguments
dotnet_diagnostic.SST1449.severity = warning # Avoid writing directly to the console
# dotnet_diagnostic.SST1450.severity = warning # Store files as UTF-8 without a byte order mark (opt-in)
dotnet_diagnostic.SST1451.severity = warning # Specify a DateTimeKind when creating a DateTime
dotnet_diagnostic.SST1452.severity = warning # Remove unused type parameters
dotnet_diagnostic.SST1453.severity = warning # Unreachable code should be removed
dotnet_diagnostic.SST1454.severity = warning # Composite format strings should match their arguments
dotnet_diagnostic.SST1455.severity = warning # Remove unnecessary unsafe modifiers
dotnet_diagnostic.SST1456.severity = warning # Mutable struct fields should not be readonly
dotnet_diagnostic.SST1457.severity = warning # Global suppressions should point at real declarations
dotnet_diagnostic.SST1458.severity = warning # Global suppression targets should use declaration ids directly
dotnet_diagnostic.SST1459.severity = warning # Remove grouping parentheses that do not group anything
dotnet_diagnostic.SST1460.severity = warning # Mark non-mutating struct members readonly
dotnet_diagnostic.SST1461.severity = warning # Remove private parameters that are never read
dotnet_diagnostic.SST1462.severity = warning # Remove suppressions for diagnostics that are already disabled
dotnet_diagnostic.SST1463.severity = warning # Use nameof for symbol-name strings
dotnet_diagnostic.SST1464.severity = warning # Unwrap else after a branch that does not fall through
dotnet_diagnostic.SST1465.severity = warning # Collapse an else block that only wraps an if
dotnet_diagnostic.SST1466.severity = warning # Remove case labels that share a section with default
dotnet_diagnostic.SST1467.severity = warning # Enumerate with foreach instead of driving the enumerator by hand
dotnet_diagnostic.SST1468.severity = warning # Boolean logic should short-circuit
dotnet_diagnostic.SST1469.severity = warning # Do not compare a value type to null
dotnet_diagnostic.SST1470.severity = warning # Remove a catch clause that only rethrows
