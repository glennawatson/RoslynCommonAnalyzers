# Correctness
dotnet_diagnostic.SST2400.severity = warning # Arguments should be passed in the parameter's order
dotnet_diagnostic.SST2401.severity = warning # Do not catch NullReferenceException
dotnet_diagnostic.SST2402.severity = warning # Instance members should not write to static fields
dotnet_diagnostic.SST2403.severity = warning # Do not let 'this' escape from a constructor
dotnet_diagnostic.SST2404.severity = warning # Validate an iterator's arguments before it starts yielding
dotnet_diagnostic.SST2405.severity = warning # DebuggerDisplay should reference members that exist
dotnet_diagnostic.SST2406.severity = warning # A loop's stop condition should be able to change
dotnet_diagnostic.SST2407.severity = warning # Declared events should be raised
dotnet_diagnostic.SST2408.severity = warning # A StringBuilder that is filled should be read
dotnet_diagnostic.SST2409.severity = warning # Do not throw a general exception type
dotnet_diagnostic.SST2410.severity = warning # A created disposable should be disposed
