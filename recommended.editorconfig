dotnet_diagnostic.SST1193.severity = warning # An object is created and then immediately assigned member values
dotnet_diagnostic.SST1194.severity = warning # A collection is created and then immediately populated with Add
dotnet_diagnostic.SST1195.severity = warning # A null fallback conditional expression can use ??
dotnet_diagnostic.SST1196.severity = warning # A null-guarded member access can use ?.
dotnet_diagnostic.SST1197.severity = warning # Adjacent return statements can use a conditional expression
dotnet_diagnostic.SST1198.severity = warning # Matching if/else assignments can use a conditional expression
