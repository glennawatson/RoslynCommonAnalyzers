dotnet_diagnostic.SST1187.severity = warning # An assignment is chained as the value of another (a = b = c)
dotnet_diagnostic.SST1188.severity = warning # A 'default(T)' is written where the bare 'default' literal suffices
dotnet_diagnostic.SST1189.severity = warning # An assignment copies a value onto itself (x = x)
