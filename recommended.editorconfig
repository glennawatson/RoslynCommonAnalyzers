dotnet_diagnostic.SST2323.severity = warning # Express an all-abstract class as an interface
dotnet_diagnostic.SST2324.severity = warning # Do not declare a member more accessible than its containing type
dotnet_diagnostic.SST2325.severity = warning # Validate an async method's arguments before its first await
